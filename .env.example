NODE_ENV=development
PORT=5000
MONGO_URI=your_mongodb_connection_string

# JSON Web Token
JWT_SECRET=this-is-a-super-secret-key-for-jwt-replace-it-with-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_COOKIE_EXPIRES_IN=90
JWT_REFRESH_SECRET=this-is-another-super-secret-key-for-refresh-tokens
JWT_REFRESH_EXPIRES_IN=365d

# Email (using Mailtrap for development)
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USERNAME=your_mailtrap_username
EMAIL_PASSWORD=your_mailtrap_password
EMAIL_FROM="E-Commerce Team <noreply@ecommerce.com>"

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Paymob
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_INTEGRATION_ID=your_card_integration_id
PAYMOB_IFRAME_ID=your_paymob_iframe_id
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret

# Fawry
FAWRY_HOST=https://atfawry.fawrystaging.com
FAWRY_MERCHANT_CODE=your_fawry_merchant_code
FAWRY_SECURITY_KEY=your_fawry_security_key

# Webhook
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret

# OpenAI System Prompt
OPENAI_SYSTEM_PROMPT="You are a friendly and helpful e-commerce assistant for the 'Gemini Store'. Your goal is to help users find products, answer questions about their orders, and provide support. Keep your answers concise and relevant to an e-commerce context."

OPENAI_EMBEDDING_MODEL=text-embedding-3-small